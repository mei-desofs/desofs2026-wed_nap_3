meta {
  name: Get Token Admin
  type: http
  seq: 2
}

post {
  url: {{auth0_domain}}/oauth/token
  body: json
  auth: inherit
}

body:json {
  {
    "client_id": "{{client_id}}",
    "client_secret": "{{client_secret}}",
    "audience": "{{audience}}",
    "grant_type": "password",
    "username": "admin@test.com",
    "password": "4dm1n@DESOFS_2026#Secure!"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("token", res.body.access_token);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
